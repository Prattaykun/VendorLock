# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_NAME=VendorLock
APP_VERSION=0.1.0
SECRET_KEY=change_me_32_chars_minimum_secret
DEBUG=true

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── PostgreSQL (direct) ───────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/vendorlock
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=vendorlock
POSTGRES_USER=vendorlock
POSTGRES_PASSWORD=vendorlock_secret

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=vendorlock

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── LLM Keys ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key
OPENAI_API_KEY=sk-your-key
GOOGLE_API_KEY=your-google-key

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=vendorlock-docs

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:8080"]

# ── FAISS ────────────────────────────────────────────────────────────────────
FAISS_INDEX_PATH=./data/faiss_index
